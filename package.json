{
  "name": "magware-api",
  "version": "1.0.0",
  "private": true,
  "description": "OpenAPI 3.1 specification for the Magware WMS REST API by Restore S.r.l.",
  "homepage": "https://api.magware.it",
  "repository": {
    "type": "git",
    "url": "https://github.com/restoresrl/magware-api"
  },
  "license": "UNLICENSED",
  "author": "Restore S.r.l. <info@re-store.it>",
  "scripts": {
    "lint:api": "spectral lint openapi/magware.yaml",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules",
    "format": "prettier --write \"**/*.{yaml,yml,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{yaml,yml,md,json}\" --ignore-path .gitignore",
    "check": "npm run lint:api && npm run lint:md && npm run format:check"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.11.1",
    "markdownlint-cli": "^0.43.0",
    "prettier": "^3.4.2"
  }
}
